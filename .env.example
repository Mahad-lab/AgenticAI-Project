# ─── PSX Multi-Agent Trading System ──────────────────────────────────────────────
# Copy this file to .env and fill in your API keys

# Model provider (groq | gemini | openai_compatible)
MODEL_PROVIDER=groq

# Groq (Recommended — Free, 14,400 requests/day)
# Get key: https://console.groq.com
GROQ_API_KEY=

# Google Gemini (Free alternative)
# Get key: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenAI-compatible (e.g., OpenAI, Together, OpenRouter)
OPENAI_API_KEY=
OAI_BASE_URL=https://api.openai.com/v1
OAI_MODEL=gpt-4o-mini
