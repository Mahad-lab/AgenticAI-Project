# Copy this file to .env and fill in your keys

# ── Choose your provider ──────────────────────────────────
MODEL_PROVIDER=groq        # groq | gemini | openai_compatible

# ── Groq (free at console.groq.com) ──────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Google Gemini (free at aistudio.google.com) ──────────
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# ── OpenAI-compatible (OpenAI, Together, Mistral, etc.) ──
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OAI_BASE_URL=https://api.openai.com/v1
OAI_MODEL=gpt-4o-mini
